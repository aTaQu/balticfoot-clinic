# PostgreSQL connection string (Railway provides this)
DATABASE_URI=postgresql://user:password@host:5432/dbname

# Secret used to sign Payload JWTs — generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-here

# Initial seed passwords (used only when no users exist in the database)
SEED_VENETA_PASSWORD=ChangeMe123!
SEED_LINA_PASSWORD=ChangeMe123!

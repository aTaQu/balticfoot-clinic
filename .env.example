# PostgreSQL connection string (Railway provides this)
DATABASE_URI=postgresql://user:password@host:5432/dbname

# Secret used to sign Payload JWTs — generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-here

# Initial seed passwords (used only when no users exist in the database)
SEED_VENETA_PASSWORD=ChangeMe123!
SEED_LINA_PASSWORD=ChangeMe123!

# Resend — transactional email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# SMSAPI — SMS notifications, sender ID "BalticFoot" (https://www.smsapi.com)
SMSAPI_TOKEN=your-smsapi-token-here

# Cron secret — used by GET /api/cron/reminders and GET /api/cron/retention (Bearer token auth)
# Trigger daily at 10:00 Europe/Vilnius via Railway cron or cron-job.org
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Public site URL — used for <link rel="canonical">; no trailing slash
# Set this on Railway before go-live
NEXT_PUBLIC_SITE_URL=https://www.podologija-siauliai.lt

# Cloudflare R2 media storage (S3-compatible)
# Create a bucket in Cloudflare R2, then generate an API token with Object Read & Write
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=your-r2-bucket-name
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
